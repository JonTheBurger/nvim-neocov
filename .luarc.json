{
  "$schema": "https://raw.githubusercontent.com/LuaLS/vscode-lua/master/setting/schema.json",
  "$comment": "https://luals.github.io/wiki/settings/",
  "diagnostics.libraryFiles": "Disable",
  "workspace.checkThirdParty": "Disable",
  "workspace.ignoreDir": [
    ".cache",
    ".luarocks",
    "*/external/*",
    "build"
  ],
  "workspace.library": [
    "${env:HOME}/.luarocks/share/lua/5.1/busted",
    "$VIMRUNTIME/lua",
    "tools/types"
  ]
}
